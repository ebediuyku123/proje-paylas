rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == "ahmet20alya20@gmail.com";
    }

    function isPublishedProject() {
      return resource.data.published == true;
    }

    match /projects/{projectId} {
      allow get: if isPublishedProject() || isAdmin();
      allow list: if isPublishedProject() || isAdmin();
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
        || (
          request.auth == null
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount', 'downloadCount'])
        );
    }

    match /settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /analytics/{document=**} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /messages/{document=**} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /feedbacks/{document=**} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /blog/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /visitors/{document=**} {
      allow read: if isAdmin();
      allow create, update: if true; // server API writes via client SDK
    }

    match /stats/{document=**} {
      allow read: if true;
      allow create, update: if true; // server API writes via client SDK
    }
  }
}
